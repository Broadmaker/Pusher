{
  "name": "push-notification-saas",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:sdk": "esbuild ./sdk/web/src/index.ts --bundle --minify --target=es2015 --format=iife --global-name=PushSDK --outfile=./public/sdk.js",
    "build": "pnpm build:sdk && tsc -b && vite build",
    "preview": "vite preview",
    "dev:worker": "pnpm --filter worker dev",
    "deploy:worker": "pnpm --filter worker deploy",
    "db:migrate": "pnpm --filter worker db:migrate"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.21.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "web-push": "^3.6.7"
  }
}
